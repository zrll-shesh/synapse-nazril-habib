# Salin file ini menjadi .env.local untuk development di VSCode,
# dan tambahkan sebagai Environment Variables di dashboard Vercel saat deploy.

# Token Hugging Face untuk memanggil model embedding all-MiniLM-L6-v2
# via Inference API (buat di https://huggingface.co/settings/tokens)
HUGGINGFACE_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# API key Gemini untuk model gemini-2.5-flash-lite
# (buat di https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
